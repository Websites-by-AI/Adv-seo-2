# Public URL of this Python deployment (no trailing slash)
PUBLIC_BASE_URL=https://YOUR-PYTHON-PROJECT.vercel.app

# Next.js → Python server-to-server authentication.
# Generate with: openssl rand -hex 32
# Save the same value as CLINIC_SIGNAL_API_TOKEN in the Next.js deployment.
CLINIC_SIGNAL_API_TOKEN=

# false keeps the standalone static Clinic Signal UI usable.
# true requires the Bearer token for all /api routes and is recommended when Next.js is the only UI.
CLINIC_SIGNAL_REQUIRE_AUTH=false

# Keep messaging disabled until every provider test, consent and approval check passes.
DRY_RUN=true
SEND_ENABLED=false

# Optional external providers (store values as hosting Secrets; never commit real keys)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
# Use either official Google Places Text Search or Brave Search for automatic candidates.
GOOGLE_PLACES_API_KEY=
# GOOGLE_MAPS_API_KEY is accepted as an alias.
BRAVE_SEARCH_API_KEY=

# Optional Supabase lead persistence (server-only key; never NEXT_PUBLIC_)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_LEADS_TABLE=clinic_leads

# Public same-origin contact/about-page enrichment (1-5 pages, robots-aware)
CONTACT_ENRICH_MAX_PAGES=3
ENRICH_REQUIRE_ROBOTS=false

# Required for stateless signed proposal links on Vercel (minimum 24 characters)
PDF_LINK_SECRET=
